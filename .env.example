# ============================================================
# RetailDWHPostgres
# Beispiel für die lokalen Umgebungsvariablen.
#
# Diese Datei darf im Git gespeichert werden.
# Die Datei ".env" enthält die tatsächlichen Werte und wird
# nicht versioniert.
# ============================================================

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=retaildw
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# Logging
LOG_LEVEL=INFO
